{
  "name": "web-project",
  "private": true,
  "workspaces": ["LaravelProjects", "PORT"],
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix LaravelProjects\" \"npm run dev --prefix PORT\"",
    "format": "prettier --write \"LaravelProjects/**/*.{js,jsx,ts,tsx,json,css,scss,html,php}\" \"PORT/**/*.{js,jsx,ts,tsx,json,css,scss,html}\"",
    "format:check": "prettier --check \"LaravelProjects/**/*.{js,jsx,ts,tsx,json,css,scss,html,php}\" \"PORT/**/*.{js,jsx,ts,tsx,json,css,scss,html}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0"
  }
}